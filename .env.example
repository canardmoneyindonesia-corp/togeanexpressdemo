# ---- Neon Postgres ----
# Copy from your Neon dashboard (use the pooled connection string).
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# ---- Xendit (test mode) ----
# Get from https://dashboard.xendit.co → Settings → API Keys (use the TEST secret key).
XENDIT_SECRET_KEY="xnd_development_..."
# Webhook verification token from Xendit → Settings → Webhooks (callback verification token).
XENDIT_WEBHOOK_TOKEN="your_xendit_webhook_verification_token"

# ---- Admin panel ----
ADMIN_PASSWORD="change-me"
# Random string used to sign the admin session cookie.
SESSION_SECRET="generate-a-long-random-string"

# ---- App ----
# Public base URL of this app (used for Xendit redirects, QR links, webhook).
# Local dev: http://localhost:3000
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
